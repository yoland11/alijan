{
  "name": "ajn-booking-tracking",
  "version": "0.1.0",
  "private": true,
  "description": "AJN booking, tracking, and admin desktop-ready app.",
  "author": "AJN",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "hash:admin": "node scripts/generate-admin-hash.mjs",
    "desktop:dev": "node scripts/electron-dev.mjs",
    "desktop:config": "node scripts/build-desktop-config.mjs",
    "desktop:package": "npm run desktop:config && electron-forge package",
    "desktop:make": "npm run lint && npm run build && npm run desktop:config && electron-forge make",
    "desktop:make:win": "npm run lint && npm run build && npm run desktop:config && electron-forge make --platform=win32 --arch=x64",
    "deploy:web": "npm run build && npx vercel --prod"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.103.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "electron": "^37.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  }
}
