NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=https://your-live-site.example.com
# Used in customer tracking links and WhatsApp messages.
APP_BASE_URL=https://your-live-site.example.com
# Optional override for the Electron desktop app:
# ELECTRON_ADMIN_URL=https://your-live-site.example.com/admin/login
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=order-media
AUTH_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash
# For local testing only, you may use ADMIN_PASSWORD instead of ADMIN_PASSWORD_HASH.
# ADMIN_PASSWORD=123456
NEXT_PUBLIC_WHATSAPP_NUMBER=9647700000000
